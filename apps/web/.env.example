# Supabase Configuration
# Get these values from your Supabase project dashboard:
# https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

# Your Supabase project URL
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Your Supabase anon/public key (safe for client-side)
# This key has Row Level Security (RLS) enforced
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional: Override landing page demo (default is bundled /videos/sommi-landing-demo.mp4)
# YouTube/Vimeo watch URL, or MP4/WebM under public/ e.g. /videos/custom.mp4
# If an older build set VITE_LANDING_DEMO_VIDEO_URL=/videos/sommi-demo.mp4, either remove it or rely on the app mapping + public/videos/sommi-demo.mp4 copy.
# VITE_LANDING_DEMO_VIDEO_URL=https://www.youtube.com/watch?v=YOUR_VIDEO_ID
# VITE_LANDING_DEMO_VIDEO_POSTER=/videos/demo-poster.jpg

# Optional: Enable service worker in development
# VITE_ENABLE_SW=true

# Optional (dev server only): replay Sommi FAB “Meet Sommi” / gold intro on every refresh; does not set intro-seen in localStorage. Production builds ignore this.
VITE_SOMMELIER_FAB_INTRO_DEBUG=true

# Paddle annual billing — set to "true" only AFTER PADDLE_PRICE_PREMIUM_YEARLY
# and PADDLE_PRICE_COLLECTOR_YEARLY are configured on the API server.
# VITE_PADDLE_YEARLY_ENABLED=true
